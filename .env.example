AEGISOPS_ENV=development
AEGISOPS_LOG_LEVEL=INFO
AEGISOPS_API_PORT=8080
AEGISOPS_MONGODB_URI=mongodb://mongodb:27017/aegisops
AEGISOPS_PROMETHEUS_URL=http://prometheus:9090
AEGISOPS_GRAFANA_URL=http://grafana:3000
AEGISOPS_TRACE_URL=http://tempo:3200
AEGISOPS_RUNBOOKS_PATH=/app/runbooks
AEGISOPS_FEATURE_SCHEMA_VERSION=feature-schema.v1
AEGISOPS_MODEL_VERSION=baseline-statistical.v1
AEGISOPS_FAULTS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

