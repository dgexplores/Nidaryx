TRACESENTRY_ENV=development
TRACESENTRY_LOG_LEVEL=INFO
TRACESENTRY_API_PORT=8080
TRACESENTRY_MONGODB_URI=mongodb://mongodb:27017/tracesentry
TRACESENTRY_PROMETHEUS_URL=http://prometheus:9090
TRACESENTRY_GRAFANA_URL=http://grafana:3000
TRACESENTRY_TRACE_URL=http://tempo:3200
TRACESENTRY_RUNBOOKS_PATH=/app/runbooks
TRACESENTRY_FEATURE_SCHEMA_VERSION=feature-schema.v1
TRACESENTRY_MODEL_VERSION=baseline-statistical.v1
TRACESENTRY_FAULTS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

