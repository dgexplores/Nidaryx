NIDARYX_ENV=development
NIDARYX_LOG_LEVEL=INFO
NIDARYX_API_PORT=8080
NIDARYX_MONGODB_URI=mongodb://mongodb:27017/nidaryx
NIDARYX_PROMETHEUS_URL=http://prometheus:9090
NIDARYX_GRAFANA_URL=http://grafana:3000
NIDARYX_TRACE_URL=http://tempo:3200
NIDARYX_RUNBOOKS_PATH=/app/runbooks
NIDARYX_FEATURE_SCHEMA_VERSION=feature-schema.v1
NIDARYX_MODEL_VERSION=baseline-statistical.v1
NIDARYX_FAULTS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-before-running
